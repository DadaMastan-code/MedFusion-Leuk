# ── MedFusion-Leuk Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in any optional values.
# No API keys are required — the system runs entirely locally via Ollama.

# Ollama LLM settings (local, free)
OLLAMA_MODEL=meditron
OLLAMA_FALLBACK_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# PubMed / NCBI E-utilities API key (optional — raises rate limits for RAG)
# Leave blank to use unauthenticated access (100 req/10s limit)
NCBI_API_KEY=

# Runtime environment: development | production
ENVIRONMENT=development

# Set to 1 to use GPU (if CUDA/MPS available), 0 to force CPU
USE_GPU=1

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
